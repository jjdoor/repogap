{
  "name": "repogap",
  "version": "0.1.0",
  "description": "Zero-dependency CLI to check a repository for missing files and manifest fields — README, LICENSE, .gitignore, CHANGELOG, and package metadata.",
  "bin": { "repogap": "bin/cli.js" },
  "main": "src/core.js",
  "scripts": { "test": "node --test" },
  "keywords": ["repo", "lint", "hygiene", "readme", "license", "gitignore", "changelog", "package", "cli", "devops", "ci"],
  "files": ["bin", "src", "README.md", "LICENSE"],
  "engines": { "node": ">=18" },
  "license": "MIT",
  "repository": { "url": "git+https://github.com/jjdoor/repogap.git" },
  "homepage": "https://github.com/jjdoor/repogap#readme",
  "bugs": { "url": "https://github.com/jjdoor/repogap/issues" }
}
